# EquiWork Environment Configuration Example
# Copy this file to .env and fill in your values
# If you don't have a .env parser, add these manually to your server environment or includes/config.php

APP_ENV=development

# Database
DB_HOST=127.0.0.1
DB_NAME=equiwork_db
DB_USER=root
DB_PASS=

# APIs
# Get your free API key at https://ocr.space/OCRAPI
OCR_API_KEY=helloworld

# Get your free Gemini API key at https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here
